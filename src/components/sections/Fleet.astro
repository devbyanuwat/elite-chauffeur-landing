<style>
  .fleet-section {
    background: var(--bg-secondary);
  }

  .fleet-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .fleet-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.3s;
  }

  .fleet-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .fleet-card.featured {
    border-color: color-mix(in oklab, var(--gold), transparent 50%);
  }

  .fleet-stage {
    position: relative;
    aspect-ratio: 5 / 4;
    display: grid;
    place-items: center;
    padding: 1.5rem 1.1rem 1.1rem;
    background: radial-gradient(120% 92% at 50% 26%, oklch(99.5% 0.003 90) 0%, var(--bg-secondary) 78%);
    overflow: hidden;
  }

  .fleet-stage::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 15%;
    width: 68%;
    height: 14px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, oklch(24% 0.02 60 / 0.26), transparent 70%);
    filter: blur(4px);
    transition: width 0.4s var(--ease-out), opacity 0.4s var(--ease-out);
    z-index: 0;
  }

  .fleet-card:hover .fleet-stage::after {
    width: 78%;
    opacity: 0.75;
  }

  .fleet-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.45s var(--ease-out);
  }

  .fleet-card:hover .fleet-img {
    transform: translateY(-6px) scale(1.04);
  }

  .fleet-tag {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    z-index: 2;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.28rem 0.62rem;
    border-radius: var(--r-pill);
    background: var(--bg-card);
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }

  .fleet-flag {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    z-index: 2;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.28rem 0.62rem;
    border-radius: var(--r-pill);
    background: var(--sun);
    color: var(--bg-dark);
  }

  .fleet-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.15rem 1.3rem 1.4rem;
    border-top: 1px solid var(--border);
  }

  .fleet-body h3 {
    font-size: 1.15rem;
    margin: 0;
  }

  .fleet-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .fleet-spec {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.73rem;
    color: var(--text-secondary);
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    padding: 0.22rem 0.55rem;
  }

  .fleet-spec svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    color: var(--text-tertiary);
  }

  .fleet-foot {
    margin-top: auto;
    padding-top: 0.95rem;
    border-top: 1px dashed var(--border);
  }

  .fleet-price {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    margin-bottom: 0.9rem;
  }

  .fleet-price small {
    font-size: 0.72rem;
    color: var(--text-tertiary);
  }

  .fleet-price b {
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: 600;
    color: var(--gold-dark);
  }

  .fleet-book {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    font-family: var(--font);
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--gold-dark);
    background: var(--gold-wash);
    border: 1.5px solid transparent;
    border-radius: var(--r-pill);
    padding: 0.72rem 1rem;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, transform 0.2s;
  }

  .fleet-book svg {
    width: 15px;
    height: 15px;
    transition: transform 0.25s var(--ease-out);
  }

  .fleet-book:hover {
    background: var(--gold-dark);
    color: #fff;
    transform: translateY(-1px);
  }

  .fleet-book:hover svg {
    transform: translateX(3px);
  }

  .fleet-book:active {
    transform: translateY(0) scale(0.985);
    transition-duration: 0.1s;
  }

  @media (max-width: 880px) {
    .fleet-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .fleet-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (function () {
    'use strict';

    /* ---------- Fleet "choose this car" -> prefill + scroll ----------
       Live behaviour called selectVtype() directly (single-file script scope).
       Here that function lives inside ServiceTabs.astro's own scoped <script>
       module and is not exported, so this component reaches the booking form
       through the same shared DOM ids (.vtype-chip / #vehicleType) instead —
       the "shared DOM ids" integration point established in BookingForm.astro
       (Task 5). This reproduces selectVtype()'s exact DOM effect (chip active
       state + hidden input value) before scrolling to #booking. */
    document.querySelectorAll('.fleet-book').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var value = (btn as HTMLElement).dataset.vtype || 'any';
        var chips = document.querySelectorAll('.vtype-chip');
        var vtypeInput = document.getElementById('vehicleType') as HTMLInputElement | null;
        chips.forEach(function (c) {
          var on = (c as HTMLElement).dataset.value === value;
          c.classList.toggle('active', on);
          c.setAttribute('aria-checked', on ? 'true' : 'false');
        });
        if (vtypeInput) vtypeInput.value = value;

        var booking = document.getElementById('booking');
        if (booking) {
          var y = booking.getBoundingClientRect().top + window.scrollY - 88;
          window.scrollTo({ top: y, behavior: 'auto' });
        }
        var pickup = document.getElementById('b_pickup') as HTMLInputElement | null;
        if (pickup) pickup.focus();
      });
    });
  })();
</script>
