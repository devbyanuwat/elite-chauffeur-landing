            <div class="fleet-price"><small data-i18n="fl.from">เริ่มต้น</small><b>฿1,000</b><small data-i18n="fl.day">/วัน</small></div>
            <button class="fleet-book" data-vtype="premium"><span data-i18n="fl.book">เลือกคันนี้</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></button>
