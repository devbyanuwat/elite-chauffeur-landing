        <blockquote data-i18n="tm.q3">"รถสะอาด คนขับใจดี เด็ก ๆ นั่งสบาย"</blockquote>
        <figcaption class="tm-author"><span class="tm-ava" aria-hidden="true">พ</span><span class="tm-meta"><b data-i18n="tm.n3">คุณพ****</b><small data-i18n="tm.r3">ทริปครอบครัว</small></span></figcaption>
      </figure>
      <figure class="tm-card tm-photo">
        <div class="tm-photo-media"><img src="/images/review-friends-day.webp" alt="ลูกค้า SABUYGO ยกนิ้วให้ระหว่างทริปธุรกิจ" loading="lazy" width="900" height="563"></div>
