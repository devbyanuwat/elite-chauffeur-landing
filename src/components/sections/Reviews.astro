<section class="block tm-section" id="reviews">
  <div class="wrap">
    <div class="section-head center reveal">
      <span class="eyebrow" data-i18n="tm.eyebrow">รีวิวจริงจากลูกค้า</span>
      <h2 data-i18n="tm.title">ลูกค้าพูดถึงเราอย่างไร</h2>
      <p data-i18n="tm.sub">เสียงส่วนหนึ่งจากผู้ที่เดินทางไปกับเรา (คำชมตัวอย่างสำหรับ mockup นี้)</p>
    </div>
  </div>

  <!-- Row 1: right to left -->
  <div class="marquee" role="group" aria-label="รีวิวลูกค้า เลื่อนอัตโนมัติ">
