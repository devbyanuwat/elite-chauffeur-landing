<style>
  .tm-section {
    background: var(--bg-secondary);
    overflow: hidden;
  }

  .tm-card {
    flex: 0 0 auto;
    width: clamp(258px, 80vw, 338px);
    margin-right: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.4rem 1.4rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    box-shadow: var(--shadow-sm);
  }

  .tm-stars {
    color: var(--gold);
    letter-spacing: 2px;
    font-size: 0.86rem;
    line-height: 1;
  }

  .tm-card blockquote {
    font-family: var(--font-display);
    font-size: 1.04rem;
    font-weight: 400;
    line-height: 1.45;
    color: var(--text-primary);
  }

  .tm-photo-media {
    border-radius: var(--r-md);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--bg-secondary);
  }

  .tm-photo-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tm-author {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: auto;
  }

  .tm-ava {
    flex: 0 0 auto;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 0.95rem;
    background: var(--gold-wash);
    color: var(--gold-dark);
  }

  .tm-ava.teal {
    background: oklch(56% 0.08 210 / 0.14);
    color: var(--green-dark);
  }

  .tm-meta b {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .tm-meta small {
    font-size: 0.78rem;
    color: var(--text-tertiary);
  }
</style>
