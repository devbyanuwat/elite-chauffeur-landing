<style>
  .cta-band {
    position: relative;
    background:
      radial-gradient(120% 140% at 100% 0%, oklch(64% 0.115 48 / 0.16) 0%, transparent 55%),
      var(--bg-dark);
    color: #fff;
    border-radius: var(--r-lg);
    padding: clamp(2.5rem, 5vw, 4rem);
    text-align: center;
    overflow: hidden;
  }

  .cta-band h2 {
    color: #fff;
    max-width: 620px;
    margin-inline: auto;
  }

  .cta-band p {
    color: oklch(82% 0.012 230);
    max-width: 520px;
    margin: 0.9rem auto 1.8rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: center;
  }

  .cta-band .btn-ghost {
    color: #fff;
    border-color: oklch(100% 0 0 / 0.35);
  }

  .cta-band .btn-ghost:hover {
    border-color: #fff;
    background: oklch(100% 0 0 / 0.08);
  }
</style>
