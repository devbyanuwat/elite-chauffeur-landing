---
import BookingForm from './BookingForm.astro';
---

<section class="hero">
  <div class="hero-bg">
    <img src="/images/hero-bg.travelv1-baseline.webp" alt="" aria-hidden="true" width="1920" height="1080" fetchpriority="high">
  </div>
  <div class="wrap wrap-wide">
    <div class="hero-grid">
      <div class="hero-copy reveal">
        <span class="hero-badge"><span class="dot"></span><span data-i18n="hero.badge">พร้อมให้บริการ 24 ชั่วโมง ทั่วไทย</span></span>
        <h1>
          <span data-i18n="hero.t1">เดินทาง</span>
          <span class="underline" data-i18n="hero.t2">สบาย ๆ</span>
          <span data-i18n="hero.t3">กับคนขับ</span>
          <span class="accent" data-i18n="hero.t4">มืออาชีพ</span>
        </h1>
        <p class="hero-lead" data-i18n="hero.lead">
          รถพร้อมคนขับสำหรับรับส่งสนามบิน เดินทางธุรกิจ และเที่ยวต่างจังหวัด
          ราคาชัดเจนตั้งแต่ต้น ประกันเต็มทุกคัน จองง่ายในไม่กี่นาที
        </p>
        <div class="hero-actions">
          <a href="#booking" class="btn btn-primary btn-lg" data-i18n="hero.cta1">ขอใบเสนอราคา</a>
          <a href="https://line.me/R/ti/p/@031cvnva" target="_blank" rel="noopener nofollow" class="btn btn-ghost btn-lg" data-i18n="hero.cta2">ปรึกษาผ่าน LINE</a>
        </div>
        <div class="hero-trust">
          <div class="hero-trust-item">
            <b>4.9<span class="stars">&#9733;</span></b>
            <span data-i18n="hero.trust1">จากลูกค้าจริง</span>
          </div>
          <div class="hero-trust-item">
            <b>500+</b>
            <span data-i18n="hero.trust2">เที่ยวปลอดภัย</span>
          </div>
          <div class="hero-trust-item">
            <b>100%</b>
            <span data-i18n="hero.trust3">ประกัน + พ.ร.บ.</span>
          </div>
        </div>
      </div>

      <!-- Booking card -->
      <div class="booking reveal" id="booking">
        <div class="booking-head">
          <h2 data-i18n="book.title">จองรถ / ขอราคา</h2>
          <span data-i18n="book.sub">ตอบกลับไว</span>
        </div>
        <BookingForm />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 128px;
    padding-bottom: clamp(3rem, 7vw, 5.5rem);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, oklch(98% 0.008 75 / 0.97) 0%, oklch(98% 0.008 75 / 0.86) 42%, oklch(98% 0.008 75 / 0.35) 100%);
  }

  @media (max-width: 880px) {
    .hero-bg::after {
      background: linear-gradient(180deg, oklch(98% 0.008 75 / 0.92) 0%, oklch(98% 0.008 75 / 0.97) 60%);
    }
  }

  .hero-grid {
    display: grid;
    /* Content-sized columns centered as a block: on wide screens the copy fills
       its column (no dead space) and the form stays a comfortable width instead
       of stretching edge-to-edge, so the pair reads as centered. minmax(0, ...)
       lets both columns shrink to fit narrower desktops without overflow. */
    grid-template-columns: minmax(0, 480px) minmax(0, 500px);
    gap: clamp(1.75rem, 3vw, 3rem);
    align-items: center;
    justify-content: center;
  }

  .hero-copy {
    max-width: 560px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    padding: 0.45rem 0.95rem 0.45rem 0.55rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-secondary);
    box-shadow: var(--shadow-sm);
    margin-bottom: 1.5rem;
  }

  .hero-badge .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 3px oklch(56% 0.08 210 / 0.18);
    animation: dot-pulse 2.8s ease-in-out infinite;
  }

  @keyframes dot-pulse {

    0%,
    100% {
      box-shadow: 0 0 0 3px oklch(56% 0.08 210 / 0.18);
    }

    50% {
      box-shadow: 0 0 0 6px oklch(56% 0.08 210 / 0.08);
    }
  }

  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4.05rem);
    font-weight: 500;
    margin-bottom: 1.25rem;
  }

  .hero h1 .accent {
    font-style: italic;
    color: var(--gold-dark);
    position: relative;
  }

  .hero h1 .underline {
    position: relative;
    white-space: nowrap;
  }

  .hero h1 .underline::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 0.28em;
    background: var(--sun);
    opacity: 0.55;
    z-index: -1;
    border-radius: 4px;
  }

  .hero-lead {
    font-size: clamp(1.02rem, 1.7vw, 1.18rem);
    color: var(--text-secondary);
    margin-bottom: 1.8rem;
    max-width: 460px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    align-items: center;
  }

  .hero-trust-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-trust-item b {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1;
  }

  .hero-trust-item span {
    font-size: 0.78rem;
    color: var(--text-tertiary);
  }

  .hero-trust .stars {
    color: var(--gold);
    letter-spacing: 2px;
    font-size: 0.9rem;
  }

  /* ---- Booking card ---- */
  .booking {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: clamp(1.5rem, 2.5vw, 2.1rem);
    box-shadow: var(--shadow-lg);
    min-width: 0;
  }

  .booking-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.3rem;
  }

  .booking-head h2 {
    font-size: 1.3rem;
    margin: 0;
  }

  .booking-head span {
    font-size: 0.78rem;
    color: var(--text-tertiary);
  }

  @media (max-width: 880px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-copy {
      max-width: none;
    }
  }

  @media (max-width: 560px) {
    .booking {
      padding: 1rem;
    }

    .hero-trust {
      gap: 1.2rem;
    }
  }

  /* Desktop: lift the hero up + tighten vertical rhythm so the whole hero
     (copy + booking form incl. submit) fits within the viewport height. */
  @media (min-width: 561px) {
    .hero {
      /* >= fixed nav height (72px) so the taller booking column never tucks
         under the nav and loses its top edge. */
      padding-top: 80px;
      padding-bottom: 36px;
    }

    .hero-badge {
      margin-bottom: 0.9rem;
    }

    .hero h1 {
      margin-bottom: 0.8rem;
    }

    .hero-lead {
      margin-bottom: 1.1rem;
    }

    .hero-actions {
      margin-bottom: 1.2rem;
    }

    .booking {
      padding: 1.1rem 1.45rem;
    }

    .booking-head {
      margin-bottom: 0.6rem;
    }
  }
</style>
