---
/**
 * Final-review B2 fix — this Nav is shared verbatim across every page
 * (homepage + 4 SEO subpages + privacy), rendered once by Base.astro. The
 * brand icon and primary CTA need different targets depending on page type:
 * on the homepage they're in-page anchors (`#`, `#booking`); on a subpage
 * the brand must return home (`/`) and the CTA must reach that page's own
 * booking form (`#bookingForm` — subpages have no `#booking` id). Defaults
 * here reproduce the pre-fix homepage markup exactly, so index.astro needs
 * no changes. The 6 section links below are made root-absolute
 * (`/#services` etc.) unconditionally — safe on every page: same-document
 * hash navigation when already on `/`, navigate-home-then-scroll otherwise.
 */
interface Props {
  brandHref?: string;
  ctaHref?: string;
}

const { brandHref = '#', ctaHref = '#booking' } = Astro.props;
---

<nav id="navbar">
  <div class="nav-inner">
    <a href={brandHref} class="nav-brand" aria-label="SABUYGO หน้าแรก">
      <img src="/images/sabuygo-logo.webp" alt="" aria-hidden="true" class="nav-logo" width="38" height="38" />
      <span class="nav-wordmark">SABUYGO</span>
    </a>

    <ul class="nav-links">
      <li><a href="/#services" data-i18n="nav.services">บริการ</a></li>
      <li><a href="/#routes" data-i18n="nav.routes">เส้นทาง</a></li>
      <li><a href="/#fleet" data-i18n="nav.fleet">รถของเรา</a></li>
      <li><a href="/#reviews" data-i18n="nav.reviews">รีวิว</a></li>
      <li><a href="/#how" data-i18n="nav.how">วิธีจอง</a></li>
      <li><a href="/#faq" data-i18n="nav.faq">คำถามบ่อย</a></li>
      <li><a href="/blog/" data-i18n="nav.blog">บทความ</a></li>
    </ul>

    <div class="nav-right">
      <div class="lang-toggle" role="group" aria-label="เปลี่ยนภาษา">
        <button type="button" data-lang="th" aria-pressed="true">TH</button>
        <button type="button" data-lang="en" aria-pressed="false">EN</button>
      </div>
      <a href={ctaHref} class="btn btn-primary nav-cta" data-i18n="nav.cta">จองรถ</a>
      <button class="nav-toggle" aria-label="เปิดเมนู" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<style>
  nav#navbar {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 1000;
    height: 72px;
    display: flex;
    align-items: center;
    background: oklch(from var(--bg-primary) l c h / 0.82);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s var(--ease-out), height 0.3s var(--ease-out),
      background 0.3s var(--ease-out);
  }

  nav#navbar.scrolled {
    height: 62px;
    border-bottom-color: var(--border);
  }

  .nav-inner {
    width: 100%;
    max-width: var(--content-wide);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
  }

  .nav-logo {
    height: 38px;
    width: auto;
  }

  .nav-wordmark {
    font-size: 1.02rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--text-primary);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    position: relative;
    color: var(--text-secondary);
    font-size: 0.88rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -6px;
    height: 1.5px;
    background: var(--gold);
    transition: right 0.3s var(--ease-out);
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  .nav-links a:hover::after {
    right: 0;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .lang-toggle {
    display: inline-flex;
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    overflow: hidden;
    background: var(--bg-card);
  }

  .lang-toggle button {
    border: none;
    background: transparent;
    font-family: var(--font);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-tertiary);
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .lang-toggle button[aria-pressed="true"] {
    background: var(--text-primary);
    color: var(--bg-primary);
  }

  .nav-cta {
    display: inline-flex;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
  }

  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: transform 0.3s var(--ease-out), opacity 0.2s;
  }

  .nav-toggle.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 880px) {
    .nav-links,
    .nav-cta {
      display: none;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-menu-open .nav-links {
      display: flex;
      position: fixed;
      inset: 72px 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0.35rem;
      background: var(--bg-primary);
      border-bottom: 1px solid var(--border);
      padding: 1.5rem clamp(1.25rem, 5vw, 2.5rem) 2rem;
      box-shadow: var(--shadow-md);
    }

    .nav-menu-open .nav-links a {
      display: block;
      padding-block: 0.6rem;
      font-size: 1rem;
    }
  }
</style>

<script>
  (function () {
    'use strict';

    /* ---------- Nav: scrolled state + mobile menu ---------- */
    /* Non-null assertions: these elements are rendered by this same
       component (Nav.astro), so they are always present at script-run
       time — matches live's unchecked DOM access, satisfies strict TS. */
    var navbar = document.getElementById('navbar')!;
    var navToggle = document.querySelector('.nav-toggle')!;
    var navInner = document.querySelector('.nav-inner');

    window.addEventListener('scroll', function () {
      navbar.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });

    navToggle.addEventListener('click', function () {
      var open = navbar.classList.toggle('nav-menu-open');
      navToggle.classList.toggle('open', open);
      navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    document.querySelectorAll('.nav-links a').forEach(function (a) {
      a.addEventListener('click', function () {
        navbar.classList.remove('nav-menu-open');
        navToggle.classList.remove('open');
        navToggle.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>
