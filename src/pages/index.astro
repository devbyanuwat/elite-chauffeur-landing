---
// TEMPORARY minimal page — still not the final homepage.
// The full section list (Stats, Services, Routes, Fleet, How, Why, FAQ,
// Testimonials, CTA band) lands in Task 6. For now this file exists so
// `npm run build` exercises Base.astro plus the Task 5 conversion core
// (Hero + ServiceTabs + BookingForm) end-to-end.
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import {
  limousineServiceSchema,
  websiteSchema,
  siteNavigationSchema,
  breadcrumbSchema,
} from '../lib/schema.ts';

const title = 'SABUYGO | Premium Car Rental & Chauffeur Service Bangkok';
const description =
  'บริการรถเช่าพร้อมคนขับระดับพรีเมียม กรุงเทพฯ รับส่งสนามบิน ธุรกิจ ท่องเที่ยว มีประกันทุกคัน คนขับผ่านการคัดสรร ปลอดภัย 24 ชม. Premium chauffeur service in Bangkok.';
const canonical = 'https://sabuygo.com';
---
<Base
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={[limousineServiceSchema, websiteSchema, siteNavigationSchema, breadcrumbSchema]}
>
  <main id="main">
    <Hero />
  </main>
</Base>
