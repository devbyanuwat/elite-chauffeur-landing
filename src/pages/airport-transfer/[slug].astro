---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BookingForm from '../../components/BookingForm.astro';

/**
 * Shared template for both airport-transfer subpages (suvarnabhumi-bkk,
 * don-mueang-dmk). Task 7 — replaces the 2 duplicated static HTML files.
 * Everything that differs between the two live pages lives in
 * src/content/airports/*.yaml (see src/content.config.ts for the schema);
 * everything byte-identical between them (nav, footer, fleet strip, vehicle
 * names/types, i18n/reveal plumbing) lives once, right here.
 */

export async function getStaticPaths() {
  const entries = await getCollection('airports');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'airports'>;
}

const { entry } = Astro.props;
const d = entry.data;

// ---- JSON-LD, built per-page from the collection entry (ported structure
// from the live <script type="application/ld+json"> blocks; only the values
// that differ between the two airports are substituted from `d`). ----
const serviceSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Airport Transfer',
  name: d.serviceName,
  description: d.serviceDescription,
  provider: {
    '@type': 'LocalBusiness',
    name: 'SABUYGO',
    url: 'https://sabuygo.com',
    telephone: '+66623879159',
    address: { '@type': 'PostalAddress', addressLocality: 'Bangkok', addressCountry: 'TH' },
  },
  areaServed: [
    { '@type': 'City', name: 'Bangkok' },
    { '@type': 'Place', name: d.areaServedPlaceName },
  ],
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'THB',
    lowPrice: d.priceLow,
    highPrice: d.priceHigh,
    offerCount: '12',
  },
  url: d.canonical,
};

const breadcrumbSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: 'https://sabuygo.com/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'รถรับส่งสนามบิน',
      item: 'https://sabuygo.com/airport-transfer/',
    },
    { '@type': 'ListItem', position: 3, name: d.breadcrumbName, item: d.canonical },
  ],
};

const faqSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: d.faq.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

// ---- Structure that never varies between the two airport pages — hardcoded
// once here rather than duplicated in each YAML entry. ----
const VEHICLES = [
  { name: 'Toyota Corolla Altis', type: 'Sedan · 3 ผู้โดยสาร · 2 กระเป๋า' },
  { name: 'Mitsubishi Xpander Cross', type: 'Crossover MPV · 6 ผู้โดยสาร · 4 กระเป๋า' },
  { name: 'Toyota Fortuner Legender', type: 'Premium SUV · 6 ผู้โดยสาร · 5 กระเป๋า' },
  { name: 'Toyota Alphard', type: 'Luxury Van · 6 ผู้โดยสาร · 6 กระเป๋า' },
] as const;

const FLEET = [
  { img: '/images/car4.webp', name: 'Toyota Corolla Altis', type: 'Executive Sedan', cap: '3 ผู้โดยสาร · 2 กระเป๋าใหญ่' },
  { img: '/images/car1.webp', name: 'Mitsubishi Xpander', type: 'Crossover MPV', cap: '6 ผู้โดยสาร · 4 กระเป๋าใหญ่' },
  { img: '/images/car3.webp', name: 'Toyota Fortuner', type: 'Premium SUV', cap: '6 ผู้โดยสาร · 5 กระเป๋าใหญ่' },
  { img: '/images/car2.webp', name: 'Toyota Alphard', type: 'Luxury Van', cap: '6 ผู้โดยสาร · 6 กระเป๋าใหญ่ · VIP' },
] as const;

const ICONS: Record<string, string> = {
  clock: '<path d="M12 2v10l4 2"/><circle cx="12" cy="12" r="10"/>',
  card: '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/>',
  clockWait: '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  luggage: '<path d="M4 12c0-4 4-8 8-8s8 4 8 8-4 8-8 8"/><path d="M9 12h6"/>',
  water: '<path d="M12 2l9 4v6c0 5-3.5 9.5-9 10-5.5-0.5-9-5-9-10V6l9-4z"/>',
};
---

<Base
  title={d.title}
  description={d.description}
  canonical={d.canonical}
  ogTitle={d.ogTitle}
  ogDescription={d.ogDescription}
  twitterTitle={d.twitterTitle}
  twitterDescription={d.twitterDescription}
  keywords={d.keywords}
  jsonLd={[serviceSchema, breadcrumbSchema, faqSchema]}
>
  <main id="main">
    <section class="hero block">
      <div class="wrap hero-inner">
        <div class="hero-text">
          <div class="breadcrumb">
            <a href="/">หน้าแรก</a>
            <span> / </span>
            <span>{d.breadcrumbLabel}</span>
          </div>
          <h1 set:html={d.heroHeadingHtml} />
          <p class="sub">{d.heroSub}</p>
          <div class="hero-trust">
            {
              d.heroTrust.map((t) => (
                <div class="hero-trust-item">
                  <svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5" /></svg>
                  <span>{t}</span>
                </div>
              ))
            }
          </div>
        </div>
        <div class="hero-form reveal">
          <BookingForm />
        </div>
      </div>
    </section>

    {
      d.related && (
        <section class="related-strip">
          <div class="wrap related-inner">
            <div>
              <h3>{d.related.heading}</h3>
              <p>{d.related.desc}</p>
            </div>
            <a href={d.related.href}>{d.related.cta}</a>
          </div>
        </section>
      )
    }

    <section class="section section-alt block">
      <div class="wrap section-inner">
        <div class="section-head reveal">
          <span class="eyebrow">Fixed Rates</span>
          <h2>ราคาคงที่ ชัดเจนตั้งแต่ต้น</h2>
          <p>{d.priceDesc}</p>
        </div>

        <table class="price-table reveal">
          <thead>
            <tr>
              <th>ประเภทรถ</th>
              {d.zoneLabels.map((z) => <th>{z}</th>)}
            </tr>
          </thead>
          <tbody>
            {
              VEHICLES.map((v, i) => (
                <tr>
                  <td data-label="ประเภทรถ">
                    <span class="veh-name">{v.name}</span>
                    <span class="veh-type">{v.type}</span>
                  </td>
                  {d.rateRows[i].map((price, zi) => (
                    <td data-label={d.zoneLabels[zi]}>
                      <span class="price-currency">฿</span>
                      <span class="price">{price.toLocaleString()}</span>
                    </td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
        <p class="price-note">{d.priceFootnote}</p>
      </div>
    </section>

    <section class="section block">
      <div class="wrap section-inner">
        <div class="section-head reveal">
          <span class="eyebrow">Service Scope</span>
          <h2>ทุกการจองรวม</h2>
          <p>{d.includedDesc}</p>
        </div>

        <div class="included-grid reveal">
          {
            d.included.map((item) => (
              <div class="included-item">
                <svg viewBox="0 0 24 24" set:html={ICONS[item.icon]} />
                <h4>{item.title}</h4>
                <p>{item.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-alt block">
      <div class="wrap section-inner">
        <div class="section-head reveal">
          <span class="eyebrow">Vehicle Options</span>
          <h2>เลือกรถตามความต้องการ</h2>
          <p>4 ประเภทรถ ครอบคลุมตั้งแต่ couple ไปจนถึง family / VIP group</p>
        </div>

        <div class="fleet-strip reveal">
          {
            FLEET.map((f) => (
              <div class="fleet-mini">
                <img src={f.img} alt={f.name} width="600" height="400" loading="lazy" />
                <h4>{f.name}</h4>
                <div class="type">{f.type}</div>
                <div class="cap">{f.cap}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section block">
      <div class="wrap section-inner faq-inner">
        <div class="section-head center reveal">
          <span class="eyebrow">FAQ</span>
          <h2>คำถามที่พบบ่อย</h2>
          <p>สงสัยเรื่องการจอง ราคา หรือบริการ? ดูคำตอบด้านล่าง — ถ้ายังไม่พบคำตอบ LINE หาเราได้</p>
        </div>

        <div class="faq-list reveal">
          {
            d.faq.map((f) => (
              <details class="faq-item">
                <summary>{f.question}</summary>
                {/* visibleAnswer overrides answer for the 2 pages/items where the
                    live visible copy differs from the live FAQPage JSON-LD text
                    by a politeness particle — JSON-LD (faqSchema above) always
                    uses f.answer verbatim, unaffected by this override. */}
                <div class="faq-answer">{f.visibleAnswer ?? f.answer}</div>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="cta-footer">
      <h2>พร้อมจอง?<br />เริ่มต้นการเดินทางที่นิ่งและมั่นใจ</h2>
      <p>กรอกฟอร์มด้านบนหรือ LINE หาเรา ทีมงานตอบกลับภายใน 15 นาที</p>
      <div class="actions">
        <a href="#bookingForm" class="btn btn-primary btn-lg">กรอกฟอร์มจอง</a>
        <a href="https://line.me/R/ti/p/@031cvnva" class="btn btn-line btn-lg" target="_blank" rel="noopener nofollow">LINE @031cvnva</a>
      </div>
    </section>
  </main>
</Base>

<style>
  /* ==================== HERO ==================== */
  .hero-inner {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
  }

  .breadcrumb {
    font-size: 0.74rem;
    letter-spacing: var(--tracking-wide);
    color: var(--text-tertiary);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .breadcrumb a {
    color: var(--text-secondary);
  }
  .breadcrumb a:hover {
    color: var(--gold-dark);
  }

  .hero-text h1 {
    font-size: clamp(1.85rem, 4.2vw, 3.1rem);
    margin-bottom: 1.25rem;
  }

  .hero-text .sub {
    font-size: clamp(1rem, 1.35vw, 1.1rem);
    color: var(--text-secondary);
    margin-bottom: 2rem;
    max-width: 540px;
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.2rem;
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .hero-trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--text-secondary);
    font-weight: 500;
  }
  .hero-trust-item svg {
    width: 14px;
    height: 14px;
    stroke: var(--green);
    fill: none;
    stroke-width: 2;
    flex-shrink: 0;
  }

  .hero-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  /* ==================== RELATED STRIP ==================== */
  .related-strip {
    background: var(--bg-secondary);
    padding: 2.5rem clamp(1.25rem, 5vw, 2.5rem);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .related-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .related-inner h3 {
    font-family: var(--font);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 0.35rem;
  }
  .related-inner p {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }
  .related-inner a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.2rem;
    border: 1px solid var(--text-primary);
    color: var(--text-primary);
    font-size: 0.85rem;
    font-weight: 500;
    border-radius: var(--r-sm);
    transition: background 0.3s, color 0.3s;
  }
  .related-inner a:hover {
    background: var(--text-primary);
    color: var(--bg-primary);
  }

  /* ==================== PRICE MATRIX ==================== */
  .price-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    overflow: hidden;
    font-size: 0.9rem;
  }
  .price-table thead th {
    background: var(--bg-secondary);
    padding: 0.95rem 1rem;
    text-align: left;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-tertiary);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  .price-table tbody td {
    padding: 1rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .price-table tbody tr:last-child td {
    border-bottom: none;
  }
  .price-table .veh-name {
    font-weight: 600;
    color: var(--text-primary);
    display: block;
  }
  .price-table .veh-type {
    display: block;
    font-size: 0.78rem;
    color: var(--text-tertiary);
    margin-top: 0.15rem;
    font-weight: 400;
  }
  .price-table .price {
    font-weight: 600;
    color: var(--text-primary);
  }
  .price-table .price-currency {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    font-weight: 400;
  }
  .price-note {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }
  @media (max-width: 700px) {
    .price-table thead {
      display: none;
    }
    .price-table tbody tr {
      display: block;
      padding: 1rem;
      border-bottom: 1px solid var(--border);
    }
    .price-table tbody tr:last-child {
      border-bottom: none;
    }
    .price-table tbody td {
      display: flex;
      justify-content: space-between;
      padding: 0.4rem 0;
      border: none;
    }
    .price-table tbody td::before {
      content: attr(data-label);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: var(--tracking-wide);
      color: var(--text-tertiary);
      font-weight: 500;
    }
  }

  /* ==================== INCLUDED GRID ==================== */
  .included-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }
  .included-item {
    padding-left: 1.5rem;
    position: relative;
    border-left: 1px solid var(--border);
  }
  .included-item svg {
    position: absolute;
    left: -12px;
    top: 4px;
    width: 22px;
    height: 22px;
    background: var(--bg-primary);
    padding: 2px;
    stroke: var(--gold-dark);
    fill: none;
    stroke-width: 1.5;
  }
  .section-alt .included-item svg {
    background: var(--bg-secondary);
  }
  .included-item h4 {
    font-family: var(--font);
    font-size: 0.92rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
  }
  .included-item p {
    font-size: 0.86rem;
    color: var(--text-secondary);
  }

  /* ==================== FLEET STRIP ==================== */
  .fleet-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) {
    .fleet-strip {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 500px) {
    .fleet-strip {
      grid-template-columns: 1fr;
    }
  }
  .fleet-mini {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    padding: 1.25rem;
    transition: border-color 0.25s, transform 0.25s var(--ease-out);
  }
  .fleet-mini:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
  }
  .fleet-mini img {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: var(--r-sm);
    margin-bottom: 0.9rem;
    background: var(--bg-secondary);
  }
  .fleet-mini h4 {
    font-family: var(--font);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .fleet-mini .type {
    font-size: 0.76rem;
    color: var(--text-tertiary);
    margin-bottom: 0.6rem;
  }
  .fleet-mini .cap {
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  /* ==================== FAQ ==================== */
  .faq-inner {
    max-width: 880px;
  }
  .faq-list {
    display: grid;
    gap: 0;
  }
  .faq-item {
    border-bottom: 1px solid var(--border);
  }
  .faq-item:first-child {
    border-top: 1px solid var(--border);
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: 1.35rem 2.5rem 1.35rem 0.25rem;
    font-weight: 500;
    font-size: 1rem;
    position: relative;
    transition: color 0.2s;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 0.5rem;
    top: 1.35rem;
    font-size: 1.3rem;
    font-weight: 300;
    color: var(--text-tertiary);
  }
  .faq-item[open] summary::after {
    content: '−';
    color: var(--gold-dark);
  }
  .faq-item[open] summary {
    color: var(--text-primary);
  }
  .faq-item summary:hover {
    color: var(--gold-dark);
  }
  .faq-answer {
    padding: 0 2.5rem 1.5rem 0.25rem;
    color: var(--text-secondary);
    font-size: 0.92rem;
    max-width: 720px;
  }

  /* ==================== CTA FOOTER ==================== */
  .cta-footer {
    padding: var(--section-spacing) clamp(1.25rem, 5vw, 3rem);
    background: var(--bg-dark);
    color: var(--bg-primary);
    text-align: center;
  }
  .cta-footer h2 {
    color: #fff;
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    margin-bottom: 0.9rem;
  }
  .cta-footer p {
    color: oklch(78% 0.008 85);
    font-size: 1rem;
    margin-bottom: 2rem;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-footer .actions {
    display: inline-flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
