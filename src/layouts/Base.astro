---
import '../styles/global.css';
import JsonLd from '../components/JsonLd.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import LineFab from '../components/LineFab.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  lang?: 'th' | 'en';
  jsonLd?: Record<string, unknown>[];
  // Per-page OG/Twitter/keywords overrides (Task 7 fix — see content.config.ts
  // seoMeta comment). ogTitle/ogDescription default to title/description;
  // twitterTitle/twitterDescription default to ogTitle/ogDescription. Pass
  // `null` for twitterTitle/twitterDescription to omit the Twitter Card block
  // entirely (live route pages have none).
  ogTitle?: string;
  ogDescription?: string;
  twitterTitle?: string | null;
  twitterDescription?: string | null;
  keywords?: string;
  // Final-review B2 fix — Nav.astro is shared verbatim across every page.
  // On the homepage the brand icon and CTA must keep their exact current
  // hrefs (in-page anchors, byte-identical to before this fix); on the 4 SEO
  // subpages they must instead return home / target that page's own
  // booking form. Defaults below reproduce the CURRENT homepage Nav markup
  // exactly, so index.astro (and privacy.astro) need no changes at all —
  // only airport-transfer/routes [slug].astro override them.
  navBrandHref?: string;
  navCtaHref?: string;
  // Final-review B1 fix — page-scoped EN dict (see content.config.ts
  // `bodyI18n` doc comment). Merged on top of the sitewide en.json by the
  // i18n boot script below; empty on pages with no subpage body copy
  // (homepage, privacy), so behavior there is unchanged.
  pageI18n?: Record<string, string>;
}

const {
  title,
  description,
  canonical,
  ogImage = '/images/logo.webp',
  lang = 'th',
  jsonLd = [],
  ogTitle = title,
  ogDescription = description,
  twitterTitle = ogTitle,
  twitterDescription = ogDescription,
  keywords = 'sabuygo, สบายโก, elite chauffeur, รถเช่าพร้อมคนขับ, รถเช่า กรุงเทพ, เช่ารถพร้อมคนขับ, รถรับส่งสนามบิน, รถเช่ารายวัน, รับส่งสุวรรณภูมิ, รับส่งดอนเมือง, airport transfer bangkok, premium car rental bangkok, รถรับส่งผู้บริหาร, corporate car service, VIP transfer, เช่ารถ VIP, private car hire thailand, chauffeur service thailand, รถเช่า เที่ยว',
  navBrandHref = '#',
  navCtaHref = '#booking',
  pageI18n = {},
} = Astro.props;

const resolvedOgImage = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="SABUYGO" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="2000" />
    <meta property="og:image:height" content="2000" />
    <meta property="og:image:alt" content="Sabuygo — Premium Car Rental & Chauffeur Service Bangkok" />
    <meta property="og:locale" content="th_TH" />
    <meta property="og:locale:alternate" content="en_US" />

    {
      twitterTitle && twitterDescription && (
        <>
          {/* Twitter Card — omitted entirely when twitterTitle/twitterDescription
              are explicitly null (live route pages emit no Twitter meta at all) */}
          <meta name="twitter:card" content="summary_large_image" />
          <meta name="twitter:title" content={twitterTitle} />
          <meta name="twitter:description" content={twitterDescription} />
          <meta name="twitter:image" content={resolvedOgImage} />
        </>
      )
    }

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/images/logo.webp" />
    <link rel="apple-touch-icon" href="/images/logo.webp" />

    <!-- Theme Color -->
    <meta name="theme-color" content="#FFFFFF" />
    <meta name="msapplication-TileColor" content="#FFFFFF" />

    {jsonLd.map((schema) => <JsonLd schema={schema} />)}

    <!-- Cloudflare Turnstile — anti-bot widget (async, non-blocking) -->
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

    <!-- Preload LCP elements: full-bleed hero photo + nav logo — ลด LCP time -->
    <link rel="preload" as="image" href="/images/hero-bg.travelv1-baseline.webp" fetchpriority="high" />
    <link rel="preload" as="image" href="/images/sabuygo-logo.webp" />

    <!-- Fonts: Anuphan (Thai) + Fraunces (display) + Hanken Grotesk (Latin) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Anuphan:wght@300;400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Hanken+Grotesk:wght@300;400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Anuphan:wght@300;400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Hanken+Grotesk:wght@300;400;500;600;700&display=swap"
      />
    </noscript>
  </head>
  <body>
    <Nav brandHref={navBrandHref} ctaHref={navCtaHref} />
    <slot />
    <Footer />
    <LineFab />

    <!-- Final-review B1 fix: page-scoped EN dict, passed as data (not a JS
         import) so the [slug].astro templates don't need their own <script>
         block. Same pattern as JsonLd.astro (type != module/none, so Astro
         leaves it un-bundled) — safe because content is author-controlled
         YAML, not user input. Empty object on pages with no subpage copy. -->
    <script type="application/json" id="page-i18n-data" set:html={JSON.stringify(pageI18n)} />

    <!-- TH/EN in-place i18n toggle - ported from live index.html "Compact i18n" script.
         Defensive: [data-i18n] elements (Task 6) and .lang-toggle buttons (Task 4 Nav)
         may not exist yet on every page; initI18n() no-ops safely when absent. -->
    <script>
      import en from '../i18n/en.json';
      import { initI18n } from '../lib/i18n';

      function boot() {
        var dict: Record<string, string> = en as Record<string, string>;
        var pageDataEl = document.getElementById('page-i18n-data');
        if (pageDataEl && pageDataEl.textContent) {
          try {
            var pageDict = JSON.parse(pageDataEl.textContent) as Record<string, string>;
            dict = Object.assign({}, dict, pageDict);
          } catch (err) {
            /* malformed page i18n data — fall back to the sitewide dict only */
          }
        }
        initI18n(dict);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', boot);
      } else {
        boot();
      }
    </script>

    <!-- Reveal on scroll — ported from live index.html inline script (~2935-2946).
         .reveal elements are rendered across many section components (Task 6),
         so this single observer lives here (global, runs once per page) rather
         than being duplicated per-component. querySelectorAll(...).forEach is
         null-safe by construction — it simply runs zero times on pages with no
         .reveal elements. -->
    <script>
      function boot() {
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!reduce && 'IntersectionObserver' in window) {
          var io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (en) {
                if (en.isIntersecting) {
                  en.target.classList.add('in');
                  io.unobserve(en.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
          );
          document.querySelectorAll('.reveal').forEach(function (el) {
            io.observe(el);
          });
        } else {
          document.querySelectorAll('.reveal').forEach(function (el) {
            el.classList.add('in');
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', boot);
      } else {
        boot();
      }
    </script>
  </body>
</html>
