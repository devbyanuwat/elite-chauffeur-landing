# ======================================================
# Elite Chauffeur — Environment Variables Template
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าให้ถูกต้อง
# ห้าม commit ไฟล์ .env ขึ้น Git!
# ======================================================

# ─────────────────────────────────────────────
# Docker Registry — สำหรับ landing page image
# ใช้ Docker Hub: docker.io
# ใช้ GHCR: ghcr.io
# ─────────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=your-github-username/elite-chauffeur-landing
IMAGE_TAG=latest

# ─────────────────────────────────────────────
# MinIO — Object Storage Credentials
# เปลี่ยนทันทีก่อน deploy!
# ─────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD_MIN_8_CHARS

# ─────────────────────────────────────────────
# Watchtower — Docker Registry Auth
# ต้องตั้งถ้า image อยู่ใน private registry
# ─────────────────────────────────────────────
# REPO_USER=your-docker-hub-username
# REPO_PASS=your-docker-hub-token-or-password
